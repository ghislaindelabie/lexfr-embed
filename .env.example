# Copy to .env and fill in. NEVER commit .env. Values are read by src/lexfr_embed/config.py.

# Hugging Face — to download gated datasets and push models/datasets
HF_TOKEN=

# Weights & Biases — optional; if unset, training falls back to report_to="none"
WANDB_API_KEY=

# Mistral — optional; synthetic query generation via the batch API (<$6 for the project)
MISTRAL_API_KEY=

# --- A1-bis distillation (all optional; defaults in config.py). Prefix LEXFR_EMBED_ ---
# LEXFR_EMBED_DISTILL=true                        # master switch for the distill stage
# LEXFR_EMBED_DISTILL_RERANKER_ID=BAAI/bge-reranker-v2-m3
# LEXFR_EMBED_DISTILL_NUM_NEGATIVES=1             # teacher candidates per query (first version = 1)
# LEXFR_EMBED_DISTILL_MINER_CKPT=results/phase1/stage1  # stage-1 embedder that mines candidates (must exist)
# LEXFR_EMBED_DISTILL_TEACHER_ACTIVATION=sigmoid  # explicit teacher transform: sigmoid | identity | tanh
# LEXFR_EMBED_DISTILL_STUDENT_SIM=cos             # MarginMSE similarity_fct: cos | dot
# LEXFR_EMBED_DISTILL_MATRYOSHKA=true             # wrap MarginMSE in MatryoshkaLoss
# LEXFR_EMBED_DISTILL_EPOCHS=1
# LEXFR_EMBED_DISTILL_LR=1e-4
